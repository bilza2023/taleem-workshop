<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Taleem Pipeline</title>

<style>
body{
  margin:0;
  background:#0f0f0f;
  color:#eee;
  font-family:system-ui, Arial;
}

.container{
  max-width:1100px;
  margin:auto;
  padding:30px 20px;
}

/* 🔝 stage nav */
.stage-nav{
  display:flex;
  gap:10px;
  margin-bottom:20px;
}

.stage-nav a{
  padding:10px 16px;
  border-radius:6px;
  text-decoration:none;
  color:#aaa;
  background:#1a1a1a;
  border:1px solid #2a2a2a;
}

.stage-nav a.active{
  background:#2c7be5;
  color:white;
}

/* header */
.header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:10px;
}

.count{
  color:#777;
  font-size:13px;
}

/* list */
.list{
  background:#161616;
  border:1px solid #2a2a2a;
  border-radius:10px;
  overflow:hidden;
}

.row{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:14px;
  border-top:1px solid #2a2a2a;
}

.row:first-child{
  border-top:none;
}

.row:hover{
  background:#1b1b1b;
}

.slug{
  font-weight:500;
}

.actions a{
  margin-left:12px;
  font-size:13px;
  color:#7db3ff;
  text-decoration:none;
}

.actions a:hover{
  text-decoration:underline;
}

.empty{
  padding:20px;
  color:#777;
}
</style>
</head>

<body>

<%- include('../partials/nav') %>

<%
  const currentStage = stage || "slides";

  const list =
    currentStage === "slides" ? slides :
    currentStage === "timings" ? timings :
    archive;
%>

<div class="container">

<!-- 🔝 NAV -->
<div class="stage-nav">
  <a href="/?stage=slides" class="<%= currentStage==='slides'?'active':'' %>">Slides</a>
  <a href="/?stage=timings" class="<%= currentStage==='timings'?'active':'' %>">Timings</a>
  <a href="/?stage=archive" class="<%= currentStage==='archive'?'active':'' %>">Archive</a>
</div>

<!-- HEADER -->
<div class="header">
  <h2><%= currentStage.toUpperCase() %></h2>
  <div class="count">Total: <%= list.length %></div>
</div>

<!-- LIST -->
<div class="list">

  <% if(list.length === 0){ %>
    <div class="empty">No decks</div>
  <% } %>

  <% list.forEach((slug, index) => { %>
    
    <div class="row">
      
      <div class="slug">
        <%= index + 1 %>. <%= slug %>
      </div>

      <div class="actions">

        <% if(currentStage === "slides"){ %>
          <a href="/editor?deck=<%= slug %>">Edit</a>
          <a href="/ui?deck=<%= slug %>">Edit-UI</a>
          <a href="/player?deck=<%= slug %>&source=slides">Play</a>
          <a href="/push/push-to-timings?deck=<%= slug %>">Push</a>
          
        <% } %>

        <% if(currentStage === "timings"){ %>
          <a href="/timings?deck=<%= slug %>">Open</a>
          <a href="/push/push-to-archive?deck=<%= slug %>">Push</a>
        <% } %>

        <% if(currentStage === "archive"){ %>
          <a href="/player?deck=<%= slug %>&source=archive" target="_blank">Play</a>
        <% } %>

      </div>

    </div>

  <% }) %>

</div>

</div>

</body>
</html>