<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Deck Library</title>

<style>

body{
  margin:0;
  background:#0f0f0f;
  color:#eee;
  font-family:system-ui, -apple-system, Arial;
}

.container{
  max-width:1100px;
  margin:auto;
  padding:40px 20px;
}

.header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:20px;
}

.count{
  color:#aaa;
  font-size:14px;
}

.search-box{
  margin-bottom:20px;
}

.search-box input{
  width:100%;
  padding:12px 14px;
  border-radius:8px;
  border:1px solid #333;
  background:#1a1a1a;
  color:#eee;
  font-size:14px;
}

.card{
  background:#161616;
  border:1px solid #2a2a2a;
  border-radius:10px;
  box-shadow:0 10px 30px rgba(0,0,0,0.35);
  overflow:hidden;
}

table{
  width:100%;
  border-collapse:collapse;
}

thead{
  background:#1f1f1f;
}

th{
  text-align:left;
  padding:14px;
  font-size:13px;
  color:#aaa;
}

td{
  padding:14px;
  border-top:1px solid #2a2a2a;
}

tr:hover{
  background:#1b1b1b;
}

.serial{
  width:60px;
  color:#777;
}

.actions a{
  margin-right:14px;
  color:#7db3ff;
  text-decoration:none;
  font-size:14px;
}

.actions a:hover{
  text-decoration:underline;
}

.deck{
  font-weight:500;
}

</style>

</head>

<body>

<%- include('../partials/nav') %>

<div class="container">

<div class="header">
<h2>Deck Library</h2>
<div class="count">
Total decks: <strong><%= decks.length %></strong>
</div>
</div>

<div class="search-box">
<input type="text" id="search" placeholder="Search decks...">
</div>

<div class="card">

<table id="deckTable">

<thead>
<tr>
<th class="serial">#</th>
<th>Deck</th>
<th>Actions</th>
</tr>
</thead>

<tbody>

<% decks.forEach((deck,index) => { %>

<tr>
<td class="serial"><%= index + 1 %></td>

<td class="deck"><%= deck %></td>

<td class="actions">

<a href="/editor?deck=<%= deck %>">Editor</a>

<a href="/player?deck=<%= deck %>" target="_blank">Player</a>

<a href="/questions?deck=<%= deck %>">Questions</a>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</div>

<script>

const searchInput = document.getElementById("search");
const rows = document.querySelectorAll("#deckTable tbody tr");

searchInput.addEventListener("keyup", function(){

  const term = this.value.toLowerCase();

  rows.forEach(row => {

    const text = row.innerText.toLowerCase();

    row.style.display = text.includes(term) ? "" : "none";

  });

});

</script>

</body>
</html>