<!DOCTYPE html>
<html>
<head>
  <style>
    body {
      margin: 0;
    }

    .app {
      background: #111;
      color: #eee;
      min-height: 100vh;
      font-family: system-ui;
    }
  </style>
</head>

<body>

<div class="app">
  <!-- EDITOR ROOT -->
  <div id="editor-root"></div>
</div>

<script>
  // ✅ Inject deck (always object, never string)
  window.__DECK__ = <%- deck ? JSON.stringify(deck) : JSON.stringify({ deck: [] }) %>;

  // ✅ Inject slug for save API
  window.__SLUG__ = "<%= slug || '' %>";

  // ✅ Callback — fired by the editor when it exports/saves the deck
  // window.__ON_SAVE__ = function(deck) {
  //   console.log("SAVE CALLBACK — deck returned from editor:", deck);
  // };
  window.__ON_SAVE__ = async function(deck) {
  const slug = window.__SLUG__;

  try {
    const res = await fetch("/ui/save", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ slug, deck })
    });

    const data = await res.json();

    console.log("SAVE RESPONSE:", data);
  } catch (err) {
    console.error("SAVE FAILED:", err);
  }
};


  // Debug (optional)
  console.log("DECK:", window.__DECK__);
  console.log("SLUG:", window.__SLUG__);
</script>

<!-- Editor styles -->
<link rel="stylesheet" href="/editor-component/assets/editor.css">

<!-- Mount script (already handles everything) -->
<script type="module" src="/editor-component/js/editor.js"></script>

</body>
</html>