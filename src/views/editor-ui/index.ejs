<!DOCTYPE html>
<html>
<head>
  <style>
    body {
      margin: 0;
    }

    .app {
      background: #111;
      color: #eee;
      min-height: 100vh;
      font-family: system-ui;
    }

    .time-bar {
      display: flex;
      gap: 10px;
      align-items: center;
      padding: 12px;
      border-bottom: 1px solid #333;
      background: #1a1a1a;
    }

    input {
      width: 80px;
      background: #000;
      color: #fff;
      border: 1px solid #333;
      padding: 4px;
    }

    button {
      background: #222;
      color: #fff;
      border: 1px solid #444;
      padding: 4px 10px;
      cursor: pointer;
    }

    button:hover {
      background: #333;
    }
  </style>
</head>

<body>

<div class="app">

  <!-- TIME BAR -->
  <div class="time-bar">
    <span>⏱ Time:</span>
    <input id="timeInput" type="number" value="0" />
    <button onclick="inc()">➕</button>
    <button onclick="dec()">➖</button>
  </div>

  <!-- EDITOR -->
  <div id="editor-root"></div>

</div>

<script>
  // ✅ GLOBAL TIME
  window.__CURRENT_TIME__ = 0;

  function inc() {
    window.__CURRENT_TIME__++;
    document.getElementById("timeInput").value = window.__CURRENT_TIME__;
  }

  function dec() {
    window.__CURRENT_TIME__--;
    document.getElementById("timeInput").value = window.__CURRENT_TIME__;
  }

  // ✅ SAFE DECK INJECTION (NO stringify issues)
  window.__DECK__ = <%- deck ? JSON.stringify(deck) : '{"deck":[]}' %>;

  console.log("DECK:", window.__DECK__);
</script>

<link rel="stylesheet" href="/editor-component/assets/editor.css">
<script type="module" src="/editor-component/js/editor.js"></script>

</body>
</html>