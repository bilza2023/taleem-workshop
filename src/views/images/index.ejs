
<!DOCTYPE html>
<html>
<head>
<title>Images Library</title>

<style>
body{
margin:0;
font-family:sans-serif;
}

.page{
max-width:900px;
margin:auto;
padding:120px 20px 40px;
}

section{
margin-bottom:40px;
}

input, textarea{
width:100%;
margin-bottom:10px;
padding:8px;
box-sizing:border-box;
}

button{
padding:8px 14px;
cursor:pointer;
}

.alert{
color:#f87171;
font-size:20px;
margin-bottom:20px;
}

body{
margin:0;
font-family:sans-serif;
background:#0f172a;
color:#e5e7eb;
}

.page{
max-width:900px;
margin:auto;
padding:120px 20px 40px;
}

section{
margin-bottom:40px;
padding:20px;
background:#111827;
border-radius:8px;
}

h1{
margin-bottom:30px;
}

h2{
margin-top:0;
margin-bottom:15px;
}

input, textarea{
width:100%;
margin-bottom:12px;
padding:10px;
box-sizing:border-box;
border-radius:6px;
border:1px solid #374151;
background:#1f2937;
color:#e5e7eb;
}

input::placeholder,
textarea::placeholder{
color:#9ca3af;
}

button{
padding:10px 16px;
cursor:pointer;
border-radius:6px;
border:none;
background:#2563eb;
color:white;
font-weight:600;
}

button:hover{
background:#1d4ed8;
}

.alert{
color:#f87171;
font-size:18px;
margin-bottom:20px;
}
</style>

</head>

<body>

<%- include('../partials/nav') %>

<div class="page">

<h1>Images Library</h1>

<% if (typeof query !== "undefined" && query.msg) { %>
<div class="alert"><%= query.msg %></div>
<% } %>

<section>

<h2>UPLOAD IMAGE</h2>

<form action="/images/upload" method="POST" enctype="multipart/form-data">

<input type="file" name="image" required>

<textarea name="prompt" placeholder="image generation prompt"></textarea>

<input name="tags" placeholder="tags (comma separated)">

<button>Upload</button>

</form>

</section>


<section>

<h2>DELETE IMAGE</h2>

<form action="/images/delete" method="POST">

<input name="filename" placeholder="filename to delete (example.webp)" required>

<button>Delete</button>

</form>

</section>


<section>

<h2>DOWNLOAD METADATA</h2>

<a href="/images/download">
<button type="button">Download images.json</button>
</a>

</section>

</div>

</body>
</html>