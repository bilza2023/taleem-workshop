<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Deck Timing Editor</title>

<style>

body{
  margin:0;
  background:#0f0f0f;
  color:#eee;
  font-family:system-ui, Arial;
}

.container{
  max-width:1100px;
  margin:auto;
  padding:40px 20px;
}

.slide{
  border:1px solid #333;
  padding:15px;
  margin-bottom:20px;
  border-radius:6px;
}

.item{
  margin-left:20px;
  margin-top:6px;
}

button{
  padding:6px 10px;
  border:none;
  border-radius:4px;
  background:#2c7be5;
  color:white;
  cursor:pointer;
  margin-left:8px;
}

input{
  width:70px;
  margin-left:10px;
}

.player{
  margin-bottom:30px;
}

.time{
  font-size:18px;
  margin-top:5px;
}

</style>
</head>

<body>

<%- include('../partials/nav') %>

<div class="container">

<h2>Timing Editor</h2>

<div class="player">
<audio id="audio" controls></audio>
<div class="time">Current Time: <span id="currentTime">0</span></div>
</div>

<div id="slides"></div>

</div>

<script>

const params = new URLSearchParams(window.location.search);
const slug = params.get("deck");

const slidesDiv = document.getElementById("slides");
const audio = document.getElementById("audio");
const currentTimeLabel = document.getElementById("currentTime");

let deck;


/* LOAD AUDIO */

function loadAudio(){

  const opus = `/content/audio/${slug}.opus`;
  const mp3 = `/content/audio/${slug}.mp3`;

  fetch(opus).then(r=>{
    if(r.ok){
      audio.src = opus;
    }else{
      audio.src = mp3;
    }
  }).catch(()=>{
    alert("No timing source found.");
  });

}


/* UPDATE CURRENT TIME */

audio.ontimeupdate = () => {
  currentTimeLabel.textContent = audio.currentTime.toFixed(2);
};


/* LOAD DECK */

async function loadDeck(){

  const res = await fetch(`/content/decks/${slug}.json`);

  if(!res.ok){
    slidesDiv.innerHTML = "Deck not found";
    return;
  }

  deck = await res.json();

  renderSlides();

}


/* RENDER SLIDES */

function renderSlides(){

  slidesDiv.innerHTML = "";

  deck.deck.forEach((slide,si)=>{

    const slideBox = document.createElement("div");
    slideBox.className = "slide";

    const startBtn = document.createElement("button");
    startBtn.textContent = "Set Slide Start";

    const startInput = document.createElement("input");
    startInput.value = slide.start || 0;

    startBtn.onclick = ()=>{
      slide.start = Math.floor(audio.currentTime);
      startInput.value = slide.start;

      if(si>0){
        deck.deck[si-1].end = slide.start;
      }
    };

    slideBox.innerHTML += `<strong>Slide ${si+1} (${slide.type})</strong>`;
    slideBox.appendChild(startBtn);
    slideBox.appendChild(startInput);

    slide.data.forEach((item,ii)=>{

      const row = document.createElement("div");
      row.className = "item";

      const label = document.createElement("span");
      label.textContent = item.name || "line";

      const btn = document.createElement("button");
      btn.textContent = "set";

      const input = document.createElement("input");
      input.value = item.showAt || 0;

      btn.onclick = ()=>{
        item.showAt = Math.floor(audio.currentTime);
        input.value = item.showAt;
      };

      row.appendChild(label);
      row.appendChild(btn);
      row.appendChild(input);

      slideBox.appendChild(row);

    });

    slidesDiv.appendChild(slideBox);

  });

}


/* INIT */

loadDeck();
loadAudio();

</script>

</body>
</html>
