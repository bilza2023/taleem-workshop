<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Deck Timing Editor</title>
<link rel="stylesheet" href="/css/timings.css">
</head>

<body>

<%- include('../partials/nav') %>

<div class="player">
<div class="player-inner">

<div class="buttons">
<button onclick="saveDeck()">Save</button>
<button onclick="playDeck()">Play</button>
</div>

<audio id="audio" controls></audio>
<div class="time">Current Time: <span id="currentTime">0</span></div>

</div>
</div>

<div class="container">

<h2>Timing Editor</h2>

<div id="slides"></div>

<div class="status" id="status"></div>

</div>

<script>

const params = new URLSearchParams(window.location.search);
const slug = params.get("deck");

const slidesDiv = document.getElementById("slides");
const audio = document.getElementById("audio");
const currentTimeLabel = document.getElementById("currentTime");
const status = document.getElementById("status");

let deck;


/* LOAD AUDIO */
function loadAudio(){

const formats = ["opus", "ogg", "mp3"];

function tryNext(i){
  if(i >= formats.length){
    alert("No timing source found.");
    return;
  }

  const url = `/content/audio/${slug}.${formats[i]}`;

  fetch(url, { method: "HEAD" })
    .then(r => {
      if(r.ok){
        audio.src = url;
      } else {
        tryNext(i + 1);
      }
    })
    .catch(() => tryNext(i + 1));
}

tryNext(0);
}
/* UPDATE CURRENT TIME */

audio.ontimeupdate = () => {
  currentTimeLabel.textContent = audio.currentTime.toFixed(2);
};


/* LOAD DECK */

async function loadDeck(){

  const res = await fetch(`/workspace/timings/${slug}.json`);

  if(!res.ok){
    slidesDiv.innerHTML = "Deck not found";
    return;
  }

  deck = await res.json();

  renderSlides();

}


/* SHORT TEXT SNIPPET */

function snippet(text){

  if(!text) return "";

  if(text.length > 200){
    return text.substring(0,200) + "...";
  }

  return text;

}


/* RENDER SLIDES */

function renderSlides(){

  slidesDiv.innerHTML = "";

  deck.deck.forEach((slide,si)=>{

    const slideBox = document.createElement("div");
    slideBox.className = "slide";

    const startBtn = document.createElement("button");
    startBtn.textContent = "Set Slide Start";

    const startInput = document.createElement("input");
    startInput.value = slide.start || 0;

    startBtn.onclick = ()=>{
      slide.start = Math.floor(audio.currentTime);
      startInput.value = slide.start;

      if(si>0){
        deck.deck[si-1].end = slide.start;
      }
    };

    slideBox.innerHTML += `<strong>Slide ${si+1} (${slide.type})</strong>`;
    slideBox.appendChild(startBtn);
    slideBox.appendChild(startInput);


    slide.data.forEach((item)=>{

      const row = document.createElement("div");
      row.className = "item";

      const btn = document.createElement("button");
      btn.textContent = "set";

      const input = document.createElement("input");
      input.value = item.showAt || 0;

      btn.onclick = ()=>{
        item.showAt = Math.floor(audio.currentTime);
        input.value = item.showAt;
      };

      const text = document.createElement("span");

      const name = item.name || "line";
      const content = snippet(item.content);

      text.textContent = ` ${name} : ${content}`;

      row.appendChild(btn);
      row.appendChild(input);
      row.appendChild(text);

      slideBox.appendChild(row);

    });

    slidesDiv.appendChild(slideBox);

  });

}


/* SAVE */
async function saveDeck(){

    if(!slug){
      alert("Slug missing.");
      return;
    }

try{

  // 🔥 SAFETY FIXES BEFORE SAVE

  if(deck && deck.deck && deck.deck.length){

    // ✅ fix first item visibility for all slides
    deck.deck.forEach(slide => {
      if(slide.data && slide.data.length){
        slide.data[0].showAt = slide.start || 0;
      }
    });

    // ✅ fix last slide end time
    const lastSlide = deck.deck[deck.deck.length - 1];

    if(audio && audio.duration){
      lastSlide.end = Math.floor(audio.duration);
    }

  }

  const res = await fetch("/timings/save",{
    method:"POST",
    headers:{ "Content-Type":"application/json" },
    body: JSON.stringify({
      slug,
      content: JSON.stringify(deck, null, 2)
    })
  });

  const data = await res.json();

  status.textContent = data.message;

  alert("Timings Saved!");

}catch(err){

  status.textContent = "Save failed.";

}

}
/* PLAY */

function playDeck(){

  if(!slug) return;

  window.open(`/player/?deck=${slug}`, "_blank");

}


/* INIT */

loadDeck();
loadAudio();

</script>

</body>
</html>
